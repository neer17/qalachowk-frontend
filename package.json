{
  "name": "qalachowk-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.13.0",
    "yarn": ">=1.22.19",
    "npm": "please-use-yarn"
  },
  "scripts": {
    "dev": "rm -rf .next && next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint --fix 'src/**/*.{js,jsx,ts,tsx}'",
    "format": "prettier --write .",
    "prettier:fix": "prettier --write --log-level warn src",
    "prepare": "husky"
  },
  "dependencies": {
    "@mantine/core": "^8.3.5",
    "@mantine/form": "^8.3.5",
    "@mantine/hooks": "^8.3.5",
